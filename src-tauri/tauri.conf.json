{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zen des Tages",
  "version": "1.0.0",
  "identifier": "de.abelssoft.zen-des-tages",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "Zen des Tages",
        "width": 600,
        "height": 500,
        "minWidth": 400,
        "minHeight": 350,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ]
  }
}
